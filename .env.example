# Copy to `.env` locally. Set the same keys in Netlify / Hostinger dashboards for production.

# Supabase (required for live CMS, auth, checkout)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Hostinger / Node server (optional — defaults shown)
# PORT=3000
# HOST=0.0.0.0
# NODE_ENV=production

# Build target (do not set in host dashboards — use npm scripts instead)
# DEPLOY_TARGET=node      → npm run build:hostinger
# DEPLOY_TARGET=netlify   → npm run build:netlify

# Deploy edge functions after migrations:
# - subscribe-newsletter
# - request-quote
# - create-checkout-session
# - verify-checkout-session
# - stripe-webhook
# - admin-stripe-config
#
# Stripe webhook URL: {SUPABASE_URL}/functions/v1/stripe-webhook
#
# Quote emails (Supabase project secrets, not in this file):
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=Astor Electronics <sales@yourdomain.com>
